{{-- ══════════════════════════════════════════════════════════════
     DONNÉES JSON (passées depuis le contrôleur)
     + JAVASCRIPT RÉACTIF
══════════════════════════════════════════════════════════════ --}}
@once
@push('scripts')
<script>
/* ── Données injectées depuis Laravel ─────────────────────────
   Remplacez les arrays JS ci-dessous par les variables Blade :
   const AGENTS = @json($agents->map(fn($a) => [...]) ?? []);
   Ici on garde des données de démo complètes pour la maquette.
──────────────────────────────────────────────────────────────*/
const AGENTS = @json(isset($agents) ? $agents->map(function($a){
  return [
    'id'       => $a->id,
    'nom'      => $a->nom,
    'prenom'   => $a->prenom,
    'mat'      => $a->matricule,
    'email'    => $a->email ?? '',
    'tel'      => $a->telephone ?? '',
    'tel_int'  => $a->telephone_interne ?? '',
    'bureau'   => $a->bureau ?? '',
    'dir_id'   => $a->entity->parent_id ?? $a->entity_id,
    'dir_nom'  => optional(optional($a->entity)->parent ?? $a->entity)->nom ?? '',
    'entity_nom'=> optional($a->entity)->nom ?? '',
    'fn_id'    => $a->fonction_id,
    'fn_lib'   => optional($a->fonction)->libelle ?? '',
    'fn_niv'   => optional($a->fonction)->niveau ?? 1,
    'date'     => optional($a->date_prise_fonction)->format('d/m/Y') ?? '',
    'active'   => $a->is_active,
    'init'     => mb_strtoupper(mb_substr($a->prenom,0,1).mb_substr($a->nom,0,1)),
    'color'    => ['#0284c7','#0369a1','#0ea5e9','#38bdf8','#0891b2','#0e7490'][crc32($a->nom)%6],
  ];
}) : collect() );



const ORG = [
  {id:1,nom:'Direction Générale',code:'DG',type:'direction',agents:1,children:[
    {id:2,nom:'Secrétariat Général',code:'DG-SG',type:'service',agents:0,children:[]}
  ]},
  {id:3,nom:'Direction des Ressources Humaines',code:'DRH',type:'direction',agents:3,children:[
    {id:4,nom:'Service Recrutement et Mobilité',code:'DRH-SRM',type:'service',agents:1,children:[
      {id:5,nom:'Département Gestion des Carrières',code:'DRH-SRM-DGC',type:'departement',agents:0,children:[]},
      {id:6,nom:'Département Relations Sociales',code:'DRH-SRM-DRS',type:'departement',agents:0,children:[]},
    ]},
    {id:7,nom:'Service Formation et Compétences',code:'DRH-SFC',type:'service',agents:0,children:[]},
  ]},
  {id:8,nom:'Direction des Affaires Financières',code:'DAF',type:'direction',agents:3,children:[
    {id:9,nom:'Service Comptabilité',code:'DAF-CPT',type:'service',agents:1,children:[]},
    {id:10,nom:'Service Budget',code:'DAF-BDG',type:'service',agents:1,children:[]},
  ]},
  {id:11,nom:"Direction des Systèmes d'Information",code:'DSI',type:'direction',agents:3,children:[
    {id:12,nom:'Service Développement',code:'DSI-DEV',type:'service',agents:2,children:[]},
    {id:13,nom:'Service Infrastructure',code:'DSI-INF',type:'service',agents:1,children:[]},
  ]},
  {id:14,nom:'Direction Juridique',code:'DJ',type:'direction',agents:2,children:[
    {id:15,nom:'Service Contentieux',code:'DJ-CNT',type:'service',agents:1,children:[]},
  ]},
  {id:16,nom:'Direction de la Communication',code:'DC',type:'direction',agents:3,children:[
    {id:17,nom:'Service Relations Presse',code:'DC-RP',type:'service',agents:1,children:[]},
  ]},
];

/* ── État ─────────────────────────────────────── */
let state = { search:'', dir:'', fn:'', niv:'', view:'grid' };
let filtered = [...DATA];

/* ── Utilitaires ──────────────────────────────── */
const niv_label = {1:'Agent',2:'Technicien',3:'Cadre',4:'Conseiller',5:'Directeur',6:'DG'};
const $  = id => document.getElementById(id);
const $$ = sel => document.querySelectorAll(sel);

function initials(str){ return str ? str.substring(0,2).toUpperCase() : '??'; }

/* ── Filtrage ─────────────────────────────────── */
function applyFilters(){
  state.search = ($('globalSearch').value || $('inlineSearch').value || '').toLowerCase().trim();
  state.dir    = $('filterDir').value;
  state.fn     = $('filterFn').value;
  state.niv    = $('filterNiv').value;

  filtered = DATA.filter(a => {
    if(!a.active) return false;
    const q = state.search;
    if(q && !`${a.nom} ${a.prenom} ${a.email} ${a.mat}`.toLowerCase().includes(q)) return false;
    if(state.dir && String(a.dir_id) !== state.dir) return false;
    if(state.fn  && String(a.fn_id)  !== state.fn)  return false;
    if(state.niv && String(a.fn_niv) !== state.niv) return false;
    return true;
  });

  $('statResults').textContent = filtered.length;
  $('filterCount').textContent = `${filtered.length} / ${DATA.filter(a=>a.active).length} agents`;
  renderGrid();
  renderList();
}

function resetFilters(){
  ['filterDir','filterFn','filterNiv'].forEach(id=>$(id).value='');
  $('inlineSearch').value='';
  $('globalSearch').value='';
  applyFilters();
}

/* ── Rendu grille ─────────────────────────────── */
function renderGrid(){
  const wrap = $('agentGrid');
  if(!filtered.length){
    wrap.innerHTML=`<div class="an-empty"><div class="an-empty-icon">🔍</div><div>Aucun agent ne correspond aux critères</div></div>`;
    return;
  }
  wrap.innerHTML = filtered.map(a=>`
    <div class="an-card" onclick="openModal(${a.id})">
      <div class="an-card-top">
        <div class="an-avatar" style="background:${a.color}">${a.init}</div>
        <div>
          <div class="an-card-name">${a.nom} ${a.prenom}</div>
          <div class="an-card-fn">${a.fn_lib}</div>
        </div>
      </div>
      <div class="an-card-meta">
        <div class="an-card-meta-row">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.69 12a19.79 19.79 0 01-3.07-8.67A2 2 0 013.6 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L7.91 8.6a16 16 0 006 6l.96-.96a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          ${a.tel || '—'}
        </div>
        <div class="an-card-meta-row">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          ${a.email || '—'}
        </div>
        <div class="an-card-meta-row">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Bureau ${a.bureau || '—'}
        </div>
      </div>
      <div class="an-card-foot">
        <span class="an-badge an-badge-entity">${a.dir_nom}</span>
        <span class="an-badge an-badge-fn" style="font-size:.68rem">Niv.${a.fn_niv}</span>
        <div class="an-dot ${a.active?'an-dot-on':'an-dot-off'}"></div>
      </div>
    </div>
  `).join('');
}

/* ── Rendu liste ──────────────────────────────── */
function renderList(){
  $('agentListBody').innerHTML = filtered.map(a=>`
    <div class="an-list-row" onclick="openModal(${a.id})">
      <div class="an-list-name">
        <div class="an-list-av" style="background:${a.color}">${a.init}</div>
        <div>
          <div style="font-weight:600;font-size:.82rem;color:#075985">${a.nom} ${a.prenom}</div>
          <div style="font-size:.72rem;color:#94a3b8">${a.mat}</div>
        </div>
      </div>
      <div><span class="an-badge an-badge-entity">${a.dir_nom}</span></div>
      <div style="font-size:.8rem;color:#475569">${a.fn_lib}</div>
      <div style="font-size:.8rem;color:#475569">${a.tel||'—'}</div>
      <div><span class="an-badge ${a.active?'an-badge-fn':'an-badge-inact'}">${a.active?'Actif':'Inactif'}</span></div>
    </div>
  `).join('');
}

/* ── Vue grille / liste ───────────────────────── */
function setView(v){
  state.view = v;
  if(v==='grid'){
    $('agentGrid').style.display='grid';
    $('agentList').classList.remove('active');
    $('btnGrid').classList.add('active'); $('btnList').classList.remove('active');
  } else {
    $('agentGrid').style.display='none';
    $('agentList').classList.add('active');
    $('btnGrid').classList.remove('active'); $('btnList').classList.add('active');
  }
}

/* ── Tabs ─────────────────────────────────────── */
function switchTab(name, btn){
  ['annuaire','orgchart','profile'].forEach(t=>{
    const el = $('tab-'+t);
    if(el) el.style.display = (t===name)?'block':'none';
  });
  $$('.an-tab').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
}

/* ── Modal fiche ──────────────────────────────── */
function openModal(id){
  const a = DATA.find(x=>x.id===id);
  if(!a) return;
  $('mAvatar').textContent = a.init;
  $('mAvatar').style.background = a.color;
  $('mName').textContent    = `${a.nom} ${a.prenom}`;
  $('mFn').textContent      = `${a.fn_lib} — Niveau ${a.fn_niv} (${niv_label[a.fn_niv]||''})`;
  $('mMat').textContent     = a.mat;
  $('mEmail').innerHTML     = a.email ? `<a href="mailto:${a.email}">${a.email}</a>` : '—';
  $('mTel').innerHTML       = a.tel   ? `<a href="tel:${a.tel}">${a.tel}</a>` : '—';
  $('mTelInt').textContent  = a.tel_int || '—';
  $('mBureau').textContent  = a.bureau  || '—';
  $('mEntity').textContent  = a.entity_nom || '—';
  $('mDir').textContent     = a.dir_nom    || '—';
  $('mFonction').textContent= a.fn_lib;
  $('mNiveau').textContent  = `Niveau ${a.fn_niv} — ${niv_label[a.fn_niv]||''}`;
  $('mDate').textContent    = a.date || '—';
  $('mStatut').innerHTML    = `<span class="an-badge ${a.active?'an-badge-fn':'an-badge-inact'}">${a.active?'✓ Actif':'✗ Inactif'}</span>`;
  $('agentModal').classList.add('open');
  document.body.style.overflow='hidden';
}
function closeModal(){
  $('agentModal').classList.remove('open');
  document.body.style.overflow='';
}
$('agentModal').addEventListener('click', e=>{ if(e.target===$('agentModal')) closeModal(); });
document.addEventListener('keydown', e=>{ if(e.key==='Escape') closeModal(); });

/* ── Organigramme ─────────────────────────────── */
function buildTree(nodes){
  const ico = {direction:,service:,departement:};
  const cls = {direction:'dir',service:'svc',departement:'dep'};
  function node(n){
    const has = n.children && n.children.length;
    return `<div class="an-tree-node">
      <div class="an-tree-row" onclick="toggleNode(this)">
        <span class="an-tree-toggle ${has?'':'leaf'}"></span>
        <span class="an-tree-icon ${cls[n.type]}">${ico[n.type]}</span>
        <span class="an-tree-name">${n.nom}</span>
        <span class="an-tree-code">${n.code}</span>
        ${n.type==='direction'&&n.agents?`<span class="an-tree-count">${n.agents} agents</span>`:''}
      </div>
      ${has?`<div class="an-tree-children">${n.children.map(node).join('')}</div>`:''}
    </div>`;
  }
  return nodes.map(node).join('');
}
function toggleNode(row){
  const toggle = row.querySelector('.an-tree-toggle');
  const kids   = row.nextElementSibling;
  if(!kids||!kids.classList.contains('an-tree-children')) return;
  toggle.classList.toggle('open');
  kids.classList.toggle('open');
}

/* ── Profil ───────────────────────────────────── */
function initProfile(){
  const name = document.querySelector('.an-profile-name')?.textContent || '';
  const init = name.split(' ').map(w=>w[0]||'').join('').substring(0,2).toUpperCase() || 'ME';
  const av = $('profileAvatar');
  if(av) av.textContent = init;
}

/* ── Statistiques ─────────────────────────────── */
function initStats(){
  const actifs = DATA.filter(a=>a.active).length;
  const dirs   = [...new Set(DATA.map(a=>a.dir_nom))].length;
  const fns    = [...new Set(DATA.map(a=>a.fn_lib))].length;
  $('statActifs').textContent  = actifs;
  $('statDirs').textContent    = dirs;
  $('statFns').textContent     = fns;
  $('statResults').textContent = actifs;
  $('filterCount').textContent = `${actifs} / ${actifs} agents`;
}

/* ── Sync recherche header + inline ──────────────*/
$('globalSearch').addEventListener('input', function(){
  $('inlineSearch').value = this.value;
  applyFilters();
});
$('inlineSearch').addEventListener('input', function(){
  $('globalSearch').value = this.value;
  applyFilters();
});

/* ── Init ─────────────────────────────────────── */
document.addEventListener('DOMContentLoaded', ()=>{
  initStats();
  applyFilters();
  $('orgTree').innerHTML = buildTree(ORG);
  initProfile();
});
</script>
@endpush
@endonce

</div>{{-- /annuaire-wrap --}}
</x-app-layout>