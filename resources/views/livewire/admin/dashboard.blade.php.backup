@push('styles')
<style>
/* ── Variables ─────────────────────────────────── */
:root {
  --sky-50:  #f0f9ff;
  --sky-100: #e0f2fe;
  --sky-200: #bae6fd;
  --sky-300: #7dd3fc;
  --sky-400: #38bdf8;
  --sky-500: #0ea5e9;
  --sky-600: #0284c7;
  --sky-700: #0369a1;
  --sky-800: #075985;
  --sky-900: #0c4a6e;
  --white:   #ffffff;
  --gray-50: #f8fafc;
  --gray-100:#f1f5f9;
  --gray-200:#e2e8f0;
  --gray-300:#cbd5e1;
  --gray-400:#94a3b8;
  --gray-500:#64748b;
  --gray-600:#475569;
  --gray-700:#334155;
  --success: #059669;
  --success-bg:#d1fae5;
  --danger:  #dc2626;
  --danger-bg:#fee2e2;
  --warn:    #d97706;
  --warn-bg: #fef3c7;
  --radius:  12px;
  --radius-sm:8px;
  --shadow:  0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
  --shadow-md:0 4px 16px rgba(2,132,199,.10);
}

/* ── Reset local ───────────────────────────────── */
.admin-dashboard * { box-sizing: border-box; }
.admin-dashboard { font-family: 'DM Sans', 'Inter', sans-serif; background: var(--sky-50); min-height: 100vh; padding: 0; }

/* ── Page header ───────────────────────────────── */
.admin-header {
  background: linear-gradient(135deg, var(--sky-700) 0%, var(--sky-500) 100%);
  padding: 2rem 2rem 3.5rem;
  position: relative; overflow: hidden;
}
.admin-header::before {
  content:''; position:absolute; right:-60px; top:-60px;
  width:260px; height:260px; border-radius:50%;
  border: 1px solid rgba(255,255,255,.12);
}
.admin-header::after {
  content:''; position:absolute; right:60px; top:40px;
  width:140px; height:140px; border-radius:50%;
  border: 1px solid rgba(255,255,255,.08);
}
.admin-header-inner { position:relative; z-index:1; max-width:1280px; margin:0 auto; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem; }
.admin-header h1 { font-size:1.6rem; font-weight:700; color:#fff; margin:0 0 .25rem; letter-spacing:-.02em; }
.admin-header-sub { font-size:.85rem; color:rgba(255,255,255,.7); }

/* ── Body container ────────────────────────────── */
.admin-body { max-width:1280px; margin:-1.8rem auto 0; padding:0 1.5rem 3rem; position:relative; z-index:2; }

/* ── Stats row ─────────────────────────────────── */
.admin-stats { display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:1rem; margin-bottom:2rem; }
.admin-stat {
  background:var(--white); border-radius:var(--radius); padding:1.5rem;
  border:1px solid var(--gray-200); box-shadow:var(--shadow);
  display:flex; align-items:center; gap:1.25rem;
  transition: box-shadow .2s;
}
.admin-stat:hover { box-shadow:var(--shadow-md); }
.admin-stat-icon {
  width:52px; height:52px; border-radius:12px; flex-shrink:0;
  display:flex; align-items:center; justify-content:center; font-size:1.4rem;
}
.admin-stat-icon.users  { background:var(--sky-100); }
.admin-stat-icon.agents { background:#ccfbf1; }
.admin-stat-icon.entities { background:#fef3c7; }
.admin-stat-icon.functions { background:#f0fdf4; }
.admin-stat-content { flex:1; }
.admin-stat-num  { font-size:2rem; font-weight:700; color:var(--sky-700); line-height:1; margin-bottom:.15rem; }
.admin-stat-lbl  { font-size:.8rem; color:var(--gray-500); text-transform:uppercase; letter-spacing:.06em; font-weight:500; }
.admin-stat-desc { font-size:.75rem; color:var(--gray-400); margin-top:.25rem; }

/* ── Content grid ──────────────────────────────── */
.admin-content { display:grid; grid-template-columns:2fr 1fr; gap:2rem; }

/* ── Recent activity ───────────────────────────── */
.admin-recent {
  background:var(--white); border:1px solid var(--gray-200); border-radius:var(--radius);
  padding:1.5rem; box-shadow:var(--shadow);
}
.admin-recent h3 {
  font-size:1.1rem; font-weight:600; color:var(--sky-800); margin:0 0 1rem;
  display:flex; align-items:center; gap:.5rem;
}
.admin-recent-list { display:flex; flex-direction:column; gap:.75rem; }
.admin-recent-item {
  display:flex; align-items:center; gap:1rem; padding:.75rem;
  border-radius:8px; background:var(--gray-50); border:1px solid var(--gray-100);
}
.admin-recent-avatar {
  width:36px; height:36px; border-radius:8px; flex-shrink:0;
  display:flex; align-items:center; justify-content:center;
  font-size:.8rem; font-weight:600; color:#fff;
}
.admin-recent-content { flex:1; }
.admin-recent-name { font-size:.85rem; font-weight:600; color:var(--sky-800); margin-bottom:.1rem; }
.admin-recent-action { font-size:.75rem; color:var(--gray-500); }
.admin-recent-time { font-size:.7rem; color:var(--gray-400); }

/* ── Quick actions ─────────────────────────────── */
.admin-actions {
  background:var(--white); border:1px solid var(--gray-200); border-radius:var(--radius);
  padding:1.5rem; box-shadow:var(--shadow);
}
.admin-actions h3 {
  font-size:1.1rem; font-weight:600; color:var(--sky-800); margin:0 0 1rem;
  display:flex; align-items:center; gap:.5rem;
}
.admin-actions-grid { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
.admin-action-btn {
  display:flex; flex-direction:column; align-items:center; gap:.5rem;
  padding:1.25rem; border-radius:10px; border:1px solid var(--gray-200);
  background:var(--white); cursor:pointer; transition:all .15s;
  text-decoration:none; color:var(--gray-700);
}
.admin-action-btn:hover {
  border-color:var(--sky-300); background:var(--sky-50);
  transform:translateY(-1px); box-shadow:0 4px 12px rgba(2,132,199,.15);
}
.admin-action-icon {
  width:48px; height:48px; border-radius:10px; display:flex; align-items:center; justify-content:center;
  font-size:1.2rem; background:var(--sky-100);
}
.admin-action-title { font-size:.8rem; font-weight:600; text-align:center; }
.admin-action-desc { font-size:.7rem; color:var(--gray-500); text-align:center; }

/* ── System info ───────────────────────────────── */
.admin-system {
  background:var(--white); border:1px solid var(--gray-200); border-radius:var(--radius);
  padding:1.5rem; box-shadow:var(--shadow); margin-top:2rem;
}
.admin-system h3 {
  font-size:1.1rem; font-weight:600; color:var(--sky-800); margin:0 0 1rem;
  display:flex; align-items:center; gap:.5rem;
}
.admin-system-grid { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
.admin-system-item {
  display:flex; align-items:center; gap:.75rem; padding:.75rem;
  border-radius:8px; background:var(--gray-50);
}
.admin-system-icon {
  width:32px; height:32px; border-radius:6px; display:flex; align-items:center; justify-content:center;
  font-size:.9rem; background:var(--sky-100);
}
.admin-system-content { flex:1; }
.admin-system-label { font-size:.75rem; color:var(--gray-500); text-transform:uppercase; letter-spacing:.05em; }
.admin-system-value { font-size:.85rem; font-weight:600; color:var(--sky-800); }

/* ── Responsive ─────────────────────────────────── */
@media(max-width:1024px) {
  .admin-content { grid-template-columns:1fr; }
  .admin-stats { grid-template-columns:repeat(2,1fr); }
}
@media(max-width:640px) {
  .admin-stats { grid-template-columns:1fr; }
  .admin-actions-grid { grid-template-columns:1fr; }
  .admin-system-grid { grid-template-columns:1fr; }
}
</style>
@endpush
@endonce

