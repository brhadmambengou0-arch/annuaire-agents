        margin: 0 auto 12px auto;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }
    .chiffre-stat {
        font-size: 28px;
        font-weight: 800;
        color: #0369a1;
        margin-bottom: 5px;
    }
    .label-stat {
        font-size: 11px;
        color: #64748b;
        text-transform: uppercase;
