    }
    .texte-bienvenue p {
        font-size: 14px;
        color: #475569;
        line-height: 1.5;
        margin: 0;
    }

    /* les 3 petites stats */
    .zone-stats {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 15px;
        margin-bottom: 25px;
    }
    .carte-stat {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 20px;
        text-align: center;
        box-shadow: 0 1px 4px rgba(0,0,0,0.05);
    }
    .icone-stat {
        width: 45px;
        height: 45px;
        background: #e0f2fe;
