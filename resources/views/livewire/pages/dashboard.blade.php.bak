        color: #075985;
        text-align: center;
        margin: 0 0 20px 0;
    }
    .grille-actions {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 15px;
    }
    .btn-action {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        padding: 20px 15px;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        text-decoration: none;
        color: #334155;
        background: white;
        transition: 0.15s;
    }
    .btn-action:hover {
        border-color: #7dd3fc;
        background: #f0f9ff;
        transform: translateY(-2px);
    }
    .icone-action {
        width: 50px;
        height: 50px;
